{
  "name": "medplum-provider",
  "version": "5.1.22",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build:bots": "npm run clean && npm run lint && tsc --noEmit -p tsconfig-bots.json && node src/scripts/build-bots.mjs && tsx src/scripts/deploy-bots.ts",
    "clean": "rimraf dist",
    "dev": "npm run build:bots && vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-organize-imports"
    ],
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "@mantine/core": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@mantine/notifications": "8.3.18",
    "@mantine/spotlight": "8.3.18",
    "@medplum/bot-layer": "5.1.22",
    "@medplum/core": "5.1.22",
    "@medplum/definitions": "5.1.22",
    "@medplum/dosespot-react": "5.1.22",
    "@medplum/eslint-config": "5.1.22",
    "@medplum/fhirtypes": "5.1.22",
    "@medplum/health-gorilla-core": "5.1.22",
    "@medplum/health-gorilla-react": "5.1.22",
    "@medplum/mock": "5.1.22",
    "@medplum/react": "5.1.22",
    "@medplum/scriptsure-react": "5.1.22",
    "@tabler/icons-react": "3.44.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.21",
    "@types/react": "19.2.17",
    "@types/react-big-calendar": "1.16.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "dayjs": "1.11.21",
    "esbuild": "^0.28.0",
    "fast-glob": "^3.3.2",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "postcss-preset-mantine": "1.18.0",
    "prettier-plugin-organize-imports": "4.3.0",
    "react": "19.2.7",
    "react-big-calendar": "1.20.0",
    "react-dom": "19.2.7",
    "react-live": "4.1.8",
    "react-markdown": "10.1.0",
    "react-router": "7.18.0",
    "recharts": "3.8.1",
    "remark-gfm": "4.0.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.18.0 || >=24.2.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.7.1",
    "phenoml": "^17.7.0"
  }
}
